PORT=5000
MONGO_URI=mongodb://localhost:27017/emergency_qrr
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=https://yourdomain.com

# ── Twilio Number Masking ─────────────────────────────────────────────────────
# HOW IT WORKS:
#   Caller sees:  your Twilio virtual number (NOT the owner's real number)
#   Owner sees:   your Twilio virtual number (NOT the caller's real number)
#   Real numbers NEVER exposed to either side.
#
# SETUP:
#  1. Go to https://console.twilio.com
#  2. Get Account SID + Auth Token from dashboard
#  3. Buy an Indian virtual number under Phone Numbers → Buy a Number
#  4. Set the number's Voice webhook to:
#       POST https://yourdomain.com/api/call/incoming
#     (For direct-dial from QR — optional, scan page flow works without this)
#  5. For local dev: use ngrok → ngrok http 5000 → use ngrok URL as BACKEND_URL
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
